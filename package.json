{
  "name": "joeanime-db-4",
  "version": "4.3.1",
  "private": true,
  "description": "JoeAnimeDB 4.3.1 SQLite Foundation",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "web": "vite",
    "desktop": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "pack:win": "electron-builder --win portable",
    "pack:dir": "electron-builder --dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "better-sqlite3": "^12.11.1",
    "concurrently": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sql.js": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.joeanimedb.app",
    "productName": "JoeAnimeDB",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
