+/* Patch 006: Home UI Fixes */
+.dailyPoster.poster,
+.miniPoster.poster,
+.recommendationPoster.poster {
+  position: relative;
+  inset: auto;
+  flex: 0 0 auto;
+  overflow: hidden;
+  isolation: isolate;
+}
+
+.dailyPoster.poster {
+  width: 130px;
+  height: 190px;
+}
+
+.miniPoster.poster {
+  width: 56px;
+  height: 76px;
+}
+
+.recommendationPoster.poster {
+  width: 150px;
+  height: 215px;
+}
+
+.dailyPoster.poster img,
+.miniPoster.poster img,
+.recommendationPoster.poster img {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+}
+
+.dailyPoster.poster span,
+.miniPoster.poster span,
+.recommendationPoster.poster span {
+  position: relative;
+  z-index: 1;
+  font-size: 18px;
+}
+
+.miniPoster.poster:after {
+  background: linear-gradient(180deg, rgba(0,0,0,.02), rgba(3,7,12,.28));
+}
+
+.daily.spotlightCard {
+  grid-template-columns: 130px minmax(0, 1fr);
+  align-items: end;
+}
+
+.recommendationCard {
+  align-items: end;
+  overflow: hidden;
+}
+
+.recommendationCard span {
+  min-width: 0;
+  position: relative;
+  z-index: 2;
+}
+
+.themePicker {
+  padding: 11px;
+}
+
+@media(max-width:1050px){
+  .daily.spotlightCard {
+    grid-template-columns: 110px minmax(0, 1fr);
+  }
+
+  .dailyPoster.poster {
+    width: 110px;
+    height: 160px;
+  }
+
+  .recommendationPoster.poster {
+    width: 110px;
+    height: 155px;
+  }
+}
