+/* Patch 008: Home Dashboard Real Polish */
+.posterThumb {
+  position: relative;
+  inset: auto;
+  display: grid;
+  place-items: center;
+  overflow: hidden;
+  isolation: isolate;
+  flex: 0 0 auto;
+  color: rgba(237,247,255,.82);
+  font-weight: 1000;
+  background: linear-gradient(135deg, rgba(55,234,255,.18), rgba(255,92,200,.16));
+}
+
+.posterThumb img {
+  position: absolute;
+  inset: 0;
+  z-index: 1;
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  display: block;
+}
+
+.posterThumb span {
+  position: relative;
+  z-index: 2;
+  font-size: 16px;
+  letter-spacing: .04em;
+}
+
+.posterThumb:after {
+  content: "";
+  position: absolute;
+  inset: 0;
+  z-index: 2;
+  pointer-events: none;
+  background: linear-gradient(180deg, rgba(0,0,0,.02), rgba(3,7,12,.20));
+}
+
+.dailyPoster.posterThumb {
+  width: 155px;
+  height: 215px;
+  border-radius: 18px;
+  box-shadow: 0 18px 38px rgba(0,0,0,.32), 0 0 24px rgba(255,92,200,.08);
+}
+
+.miniPoster.posterThumb {
+  width: 74px;
+  height: 74px;
+  border-radius: 14px;
+  box-shadow: 0 10px 24px rgba(0,0,0,.25);
+}
+
+.recommendationPoster.posterThumb {
+  width: 210px;
+  height: 250px;
+  border-radius: 18px;
+  box-shadow: 0 16px 38px rgba(0,0,0,.34), 0 0 26px rgba(55,234,255,.08);
+}
+
+.homeHero {
+  border-color: rgba(55,234,255,.32);
+  box-shadow: 0 0 0 1px rgba(255,92,200,.08), 0 20px 60px rgba(0,0,0,.24);
+}
+
+.spotlightCard {
+  grid-template-columns: 155px minmax(0,1fr) !important;
+  align-items: center;
+  min-height: 250px;
+  padding: 22px;
+  background: radial-gradient(circle at 80% 10%, rgba(255,92,200,.16), transparent 42%), rgba(7,10,21,.72);
+}
+
+.spotlightCard div strong {
+  font-size: 30px;
+}
+
+.homeStats div {
+  position: relative;
+  padding-left: 70px;
+}
+
+.homeStats div:before {
+  content: "";
+  position: absolute;
+  left: 26px;
+  top: 50%;
+  width: 30px;
+  height: 30px;
+  border-radius: 999px;
+  transform: translateY(-50%);
+  background: rgba(55,234,255,.12);
+  box-shadow: 0 0 24px rgba(55,234,255,.16);
+}
+
+.homeStats div:nth-child(1):before { background: rgba(185,132,255,.18); box-shadow: 0 0 24px rgba(185,132,255,.22); }
+.homeStats div:nth-child(2):before { background: rgba(255,92,200,.18); box-shadow: 0 0 24px rgba(255,92,200,.22); }
+.homeStats div:nth-child(3):before { background: rgba(55,234,255,.18); box-shadow: 0 0 24px rgba(55,234,255,.22); }
+.homeStats div:nth-child(4):before { background: rgba(18,214,111,.18); box-shadow: 0 0 24px rgba(18,214,111,.22); }
+.homeStats div:nth-child(5):before { background: rgba(255,201,40,.18); box-shadow: 0 0 24px rgba(255,201,40,.22); }
+
+.miniAnimeRow {
+  grid-template-columns: 74px 1fr auto;
+  min-height: 92px;
+  padding: 10px 14px;
+}
+
+.miniAnimeRow:after {
+  content: "›";
+  color: rgba(237,247,255,.75);
+  font-size: 30px;
+  line-height: 1;
+}
+
+.recommendationCard {
+  grid-template-columns: 210px minmax(0,1fr) auto;
+  align-items: center;
+  min-height: 285px;
+  padding: 18px;
+  background: radial-gradient(circle at 15% 10%, rgba(55,234,255,.12), transparent 35%), radial-gradient(circle at 90% 0%, rgba(255,92,200,.10), transparent 42%), rgba(7,10,21,.58);
+}
+
+.recommendationCard:after {
+  content: "›";
+  color: rgba(237,247,255,.78);
+  font-size: 42px;
+}
+
+.recommendationCard strong {
+  font-size: 32px;
+}
+
+.themeButtons {
+  grid-template-columns: 1fr 1fr !important;
+}
+
+.themeButtons button {
+  position: relative;
+  justify-content: flex-start;
+  min-height: 44px;
+  padding-left: 42px;
+  overflow: hidden;
+}
+
+.themeButtons button:before {
+  content: "";
+  position: absolute;
+  left: 12px;
+  top: 50%;
+  width: 20px;
+  height: 20px;
+  border-radius: 999px;
+  transform: translateY(-50%);
+  background: var(--cyan);
+  box-shadow: 0 0 18px var(--cyan);
+}
+
+.themeButtons button:nth-child(1):before { background: #37eaff; box-shadow: 0 0 18px #37eaff; }
+.themeButtons button:nth-child(2):before { background: #ff7abf; box-shadow: 0 0 18px #ff7abf; }
+.themeButtons button:nth-child(3):before { background: #b984ff; box-shadow: 0 0 18px #b984ff; }
+.themeButtons button:nth-child(4):before { background: #ffbe0b; box-shadow: 0 0 18px #ffbe0b; }
+.themeButtons button:nth-child(5):before { background: #ff3b30; box-shadow: 0 0 18px #ff3b30; }
+.themeButtons button:nth-child(6):before { background: #22002f; box-shadow: 0 0 18px #9b5cff; }
+
+@media(max-width:1050px){
+  .spotlightCard { grid-template-columns: 120px minmax(0,1fr) !important; }
+  .dailyPoster.posterThumb { width: 120px; height: 170px; }
+  .recommendationCard { grid-template-columns: 125px minmax(0,1fr); }
+  .recommendationCard:after { display:none; }
+  .recommendationPoster.posterThumb { width: 125px; height: 170px; }
+}
+
