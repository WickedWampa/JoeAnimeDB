 .bootCard p {
   color: #9fb2c8;
 }
+
+
+/* Sprint 4: Operation Glow Up */
+.shell{background:radial-gradient(circle at 10% 0%,rgba(55,234,255,.12),transparent 30%),radial-gradient(circle at 90% 10%,rgba(255,92,200,.10),transparent 32%),linear-gradient(180deg,var(--bg),#07111b 60%,#03060b)}
+.theme-neon{--bg:#050910;--panel:rgba(13,22,34,.82);--line:rgba(55,234,255,.18);--cyan:#37eaff;--pink:#ff5cc8;--gold:#ffc928;--text:#edf7ff;--muted:#9fb1c7}
+.theme-sakura{--bg:#10070d;--panel:rgba(32,13,26,.86);--line:rgba(255,145,196,.26);--cyan:#ffd1e8;--pink:#ff7abf;--gold:#ffd166;--text:#fff3f9;--muted:#d5a9bf}
+.theme-vapor{--bg:#09051a;--panel:rgba(23,13,46,.86);--line:rgba(185,132,255,.28);--cyan:#7df9ff;--pink:#ff71ce;--gold:#f8d66d;--text:#f7f0ff;--muted:#bbaee0}
+.theme-ramen{--bg:#100b05;--panel:rgba(31,21,11,.86);--line:rgba(255,179,71,.26);--cyan:#ffd166;--pink:#ff8552;--gold:#ffbe0b;--text:#fff7e8;--muted:#d2b48c}
+
+.themePicker{margin:16px 0 12px;padding:12px;border:1px solid rgba(255,255,255,.08);border-radius:16px;background:rgba(255,255,255,.035)}
+.themeTitle{display:flex;gap:8px;align-items:center;color:var(--muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}.themeButtons{display:grid;grid-template-columns:1fr 1fr;gap:7px}.themeButtons button{justify-content:center;padding:8px 10px;font-size:12px;border-color:rgba(255,255,255,.1)}.themeButtons button.active{color:var(--gold);border-color:rgba(255,201,40,.45);background:rgba(255,201,40,.11)}
+
+.favoriteButton,.favoriteListButton,.favoriteToggle{transition:transform .16s ease,border-color .16s ease,box-shadow .16s ease,background .16s ease}.favoriteButton:hover,.favoriteListButton:hover,.favoriteToggle:hover{transform:scale(1.08)}.favoriteToggle.active,.favoriteButton:has(+ .ribbon){animation:heartPop .22s ease}.animeCard.isFavorite:before{content:"";position:absolute;inset:-1px;z-index:3;pointer-events:none;border-radius:22px;box-shadow:inset 0 0 0 1px rgba(255,92,200,.45),0 0 36px rgba(255,92,200,.12)}@keyframes heartPop{0%{transform:scale(.92)}65%{transform:scale(1.12)}100%{transform:scale(1)}}
+
+.upgradedModal{grid-template-columns:290px 1fr;background:linear-gradient(135deg,rgba(55,234,255,.08),rgba(255,92,200,.045)),#07101a}.detailArtRail{display:flex;flex-direction:column;gap:14px}.detailBody{min-width:0}.heroFavorite{width:100%;justify-content:center;border:1px solid rgba(255,92,200,.25);background:rgba(255,92,200,.08);color:var(--text);border-radius:16px;padding:13px 16px;font-weight:1000;cursor:pointer}.heroFavorite.active{color:#fff;border-color:rgba(255,92,200,.55);box-shadow:0 0 28px rgba(255,92,200,.18)}
+
+.scoreEditor{border:1px solid rgba(255,255,255,.1);background:linear-gradient(135deg,rgba(55,234,255,.08),rgba(255,92,200,.06));border-radius:18px;padding:14px;margin:16px 0;display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center}.scoreEditor input[type="range"]{grid-column:1 / -1;width:100%;accent-color:var(--gold);cursor:pointer}.controlLabel{display:block;color:var(--muted);font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px}.starDisplay{display:flex;gap:2px;font-size:24px;letter-spacing:1px;color:rgba(255,255,255,.16);filter:drop-shadow(0 0 12px rgba(255,201,40,.08))}.starDisplay .filled{color:var(--gold);text-shadow:0 0 18px rgba(255,201,40,.26)}.scoreEditor strong{font-size:32px;color:var(--gold);text-shadow:0 0 24px rgba(255,201,40,.18)}
+
+.glowPanel{display:grid;grid-template-columns:1fr 170px;gap:14px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.045);border-radius:18px;padding:14px;margin:16px 0}.statusControl select{width:100%;margin-top:10px;background:#060b12;color:var(--text);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:10px}.statusPill{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;border:1px solid rgba(255,255,255,.14);padding:8px 12px;font-size:12px;font-weight:1000;text-transform:uppercase;letter-spacing:.06em;background:rgba(255,255,255,.07);color:var(--text)}.statusPill:before{content:"";width:8px;height:8px;border-radius:999px;margin-right:7px;background:var(--muted)}.statusPill.watching:before,.statusPill.watching{border-color:rgba(18,214,111,.35)}.statusPill.watching:before{background:var(--green)}.statusPill.completed:before,.statusPill.completed{border-color:rgba(55,234,255,.35)}.statusPill.completed:before{background:var(--cyan)}.statusPill.hold:before,.statusPill.hold{border-color:rgba(255,201,40,.38)}.statusPill.hold:before{background:var(--gold)}.statusPill.dropped:before,.statusPill.dropped{border-color:rgba(255,92,92,.38)}.statusPill.dropped:before{background:#ff5c5c}.statusPill.plan:before,.statusPill.plan{border-color:rgba(185,132,255,.38)}.statusPill.plan:before{background:var(--purple)}.statusPill.compact{padding:6px 9px;font-size:11px}.statusPill.ontowatch,.statusPill.plantowatch{border-color:rgba(185,132,255,.38)}
+
+.rewatchControl{display:flex;flex-direction:column}.stepper{display:grid;grid-template-columns:42px 1fr 42px;gap:8px;align-items:center}.stepper button{width:42px;height:42px;border-radius:14px;border:1px solid rgba(255,255,255,.12);background:rgba(0,0,0,.25);color:var(--text);font-size:24px;cursor:pointer}.stepper button:hover{border-color:rgba(55,234,255,.38);box-shadow:0 0 18px rgba(55,234,255,.12)}.stepper strong{text-align:center;color:var(--cyan);font-size:28px}.polishedNotes{grid-column:1 / -1}.polishedNotes textarea{width:100%;min-height:120px;resize:vertical;background:rgba(0,0,0,.26);color:var(--text);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:14px;outline:0;line-height:1.45}.polishedNotes textarea:focus{border-color:rgba(55,234,255,.38);box-shadow:0 0 0 3px rgba(55,234,255,.08)}
+
+.synopsisBlock{border-top:1px solid rgba(255,255,255,.08);margin-top:16px;padding-top:12px}.synopsisBlock h2{margin:0 0 8px;color:var(--cyan);font-size:18px}.synopsisBlock p{line-height:1.45}.emptyState{border:1px solid var(--line);background:var(--panel);border-radius:22px;padding:34px;text-align:center;color:var(--muted)}.emptyState h2{color:var(--text);margin-top:0}.bootSubline{margin-top:-6px!important;color:var(--cyan)!important;font-weight:800}
+
+@media(max-width:1050px){.upgradedModal{grid-template-columns:1fr}.glowPanel{grid-template-columns:1fr}.detailArtRail{max-width:320px}}
