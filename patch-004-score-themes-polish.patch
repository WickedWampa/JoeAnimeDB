+function scoreMoodClass(value) {
+  const rating = Number(value || 0);
+  if (rating >= 9) return 'scoreElite';
+  if (rating >= 7) return 'scoreGood';
+  if (rating >= 5) return 'scoreWarm';
+  return 'scoreLow';
+}
