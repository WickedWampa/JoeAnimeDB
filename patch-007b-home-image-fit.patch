diff --git a/src/styles/app.css b/src/styles/app.css
--- a/src/styles/app.css
+++ b/src/styles/app.css
@@
 @media(max-width:1050px){.homeHero,.homeGrid{grid-template-columns:1fr}.homeHeroText h1{font-size:46px}.recommendationCard{grid-template-columns:110px 1fr}.recommendationPoster{width:110px;height:155px}}
+
+/* Patch 007b: force home dashboard artwork to behave like real thumbnails */
+.miniPoster.poster,
+.dailyPoster.poster,
+.recommendationPoster.poster {
+  position: relative;
+  inset: auto;
+  flex: 0 0 auto;
+  overflow: hidden;
+  display: block;
+  place-items: initial;
+  font-size: 0;
+}
+
+.miniPoster.poster img,
+.dailyPoster.poster img,
+.recommendationPoster.poster img {
+  position: absolute;
+  inset: 0;
+  z-index: 1;
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  object-position: center center;
+}
+
+.miniPoster.poster span,
+.dailyPoster.poster span,
+.recommendationPoster.poster span {
+  position: relative;
+  z-index: 2;
+  display: grid;
+  place-items: center;
+  width: 100%;
+  height: 100%;
+  font-size: 18px;
+}
+
+.miniPoster.poster:after,
+.dailyPoster.poster:after,
+.recommendationPoster.poster:after {
+  content: "";
+  position: absolute;
+  inset: 0;
+  z-index: 2;
+  pointer-events: none;
+  background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,.12));
+}
+
+.miniAnimeRow {
+  grid-template-columns: 86px 1fr auto;
+  min-height: 82px;
+}
+
+.miniAnimeRow:after {
+  content: "›";
+  color: rgba(237,247,255,.7);
+  font-size: 30px;
+  line-height: 1;
+  padding-right: 6px;
+}
+
+.miniPoster.poster {
+  width: 72px;
+  height: 54px;
+  border-radius: 12px;
+  box-shadow: 0 10px 24px rgba(0,0,0,.28);
+}
+
+.dailyPoster.poster {
+  width: 150px;
+  height: 210px;
+  border-radius: 18px;
+  box-shadow: 0 18px 36px rgba(0,0,0,.32);
+}
+
+.recommendationCard {
+  grid-template-columns: 210px 1fr auto;
+  align-items: center;
+}
+
+.recommendationCard:after {
+  content: "›";
+  color: rgba(237,247,255,.72);
+  font-size: 38px;
+  line-height: 1;
+  padding-right: 4px;
+}
+
+.recommendationPoster.poster {
+  width: 190px;
+  height: 250px;
+  border-radius: 18px;
+  box-shadow: 0 18px 42px rgba(0,0,0,.34);
+}
+
+.homeHero {
+  box-shadow: inset 0 0 0 1px rgba(55,234,255,.08), 0 0 42px rgba(55,234,255,.08);
+}
+
+.stats.homeStats div:nth-child(1) strong { color: var(--purple); text-shadow: 0 0 24px rgba(185,132,255,.28); }
+.stats.homeStats div:nth-child(2) strong { color: var(--pink); text-shadow: 0 0 24px rgba(255,92,200,.28); }
+.stats.homeStats div:nth-child(3) strong { color: var(--cyan); text-shadow: 0 0 24px rgba(55,234,255,.28); }
+.stats.homeStats div:nth-child(4) strong { color: var(--green); text-shadow: 0 0 24px rgba(18,214,111,.22); }
+.stats.homeStats div:nth-child(5) strong { color: var(--gold); text-shadow: 0 0 24px rgba(255,201,40,.26); }
+
+.themeButtons button {
+  position: relative;
+  padding-left: 28px;
+  justify-content: flex-start;
+}
+
+.themeButtons button:before {
+  content: "";
+  width: 14px;
+  height: 14px;
+  border-radius: 999px;
+  position: absolute;
+  left: 9px;
+  top: 50%;
+  transform: translateY(-50%);
+  background: var(--cyan);
+  box-shadow: 0 0 16px currentColor;
+}
+
+.themeButtons button:nth-child(1):before { background:#37eaff; box-shadow:0 0 16px #37eaff; }
+.themeButtons button:nth-child(2):before { background:#ff7abf; box-shadow:0 0 16px #ff7abf; }
+.themeButtons button:nth-child(3):before { background:#8b5cf6; box-shadow:0 0 16px #8b5cf6; }
+.themeButtons button:nth-child(4):before { background:#ffbe0b; box-shadow:0 0 16px #ffbe0b; }
+.themeButtons button:nth-child(5):before { background:#ff3b30; box-shadow:0 0 16px #ff3b30; }
+.themeButtons button:nth-child(6):before { background:#3b0764; box-shadow:0 0 16px #9d4edd; }
+
+@media(max-width:1050px){
+  .recommendationCard{grid-template-columns:120px 1fr auto}
+  .recommendationPoster.poster{width:110px;height:150px}
+  .dailyPoster.poster{width:120px;height:170px}
+}
